# =========================
# 操作系统生成的文件
# =========================
# macOS 系统的目录自定义属性和缩略图缓存
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows 系统的缩略图缓存
ehthumbs.db
Thumbs.db

# =========================
# 编辑器和 IDE 相关配置
# =========================
# VS Code 工作区配置文件目录
.vscode/
# JetBrains IDE (如 WebStorm, RubyMine, IntelliJ) 配置文件目录
.idea/
# Vim 等编辑器产生的临时交换文件和备份文件
*.swp
*.swo
*~

# =========================
# Jekyll (当前工程框架) 相关的生成文件和缓存
# =========================
# Jekyll 编译生成的静态网站最终文件目录（每次构建都会重新生成，不应提交）
_site/
# Sass 编译时的缓存目录，用于加速样式编译
.sass-cache/
# Jekyll 4+ 版本引入的全局缓存目录，用于加速构建过程
.jekyll-cache/
# Jekyll 增量构建时用于记录文件变动状态的元数据文件
.jekyll-metadata

# =========================
# Ruby 依赖包和环境 (Gem)
# =========================
# 局部安装的 gem 依赖包路径（如果配置了本地 vendor 目录则忽略）
vendor/bundle/
vendor/cache/
vendor/ruby/
# 忽略打包生成的 gem 压缩包
*.gem
# Bundler 的本地运行配置文件
.bundle/

# =========================
# Node.js 依赖 (前端工程常见备用)
# =========================
# Node 依赖包存放目录，体积通常很大且可通过 package.json 重新安装
node_modules/
# NPM/Yarn 运行出错时的日志文件
npm-debug.log
yarn-error.log

# =========================
# 环境变量和机密敏感文件
# =========================
# 存放本地开发环境变量的文件，通常包含数据库密码、API 密钥等，严禁提交
.env
.env.local
